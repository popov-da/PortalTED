<hotspot id="fig-003-gra-001-hot-005" applicationStructureIdent="AUTOID_064" applicationStructureName="ИНДУКТИВНЫЙ ДАТЧИК М12"></hotspot>
<hotspot id="fig-003-gra-001-hot-006" applicationStructureIdent="AUTOID_021" applicationStructureName="ВИЛКА"></hotspot>
