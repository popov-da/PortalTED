umber="Loctite 243" data-supplyNumberType="sp01">Loctite 243</div></td><td><div class="reqQuantity"></div></td><td></td></tr>				</tbody></table></span>				<span class="reqSpares prelimTable formalTable" id="reqSpares_IDF1P2PKQ5"><table><caption></caption><caption class="rest"></caption><thead><tr><th class="prelimTable__name"></th><th class="prelimTable__identification"></th><th class="prelimTable__qty"></th><th class="prelimTable__remark"></th></tr></thead><tbody>					<tr class="row__noSpares"><td class="noSpares" colspan="4"></td></tr>				</tbody></table></span>				<div class="reqSafety">					<div class="safetyRqmts">						<div><div class="warning" id="wrn-001">							<div class="warningAndCautionPara p">РАБОТЫ ВЫПОЛНЯТЬ БЕЗ УСТАНОВЛЕННОГО ГРУЗА.</div>							<div class="warningAndCautionPara p">РАБОТЫ ВЫПОЛНЯТЬ НА ОБЕСТОЧЕННОМ ОБОРУДОВАНИИ.</div>						</div></div>					</div>				</div>			</div>			<div><div class="mainProcedure" id="mainProcedure_ID2IUNHPWE"></div></div><div class="Procedure levels" id="">				<div class="proceduralStep level1 link" id="proceduralStep_IDIY3IM4AH">					<div class="title">Демонтаж</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDXNW4JMSK">						<div class="para p">Отверните винты крепления пластин.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDSZLOAGYL">						<div class="para p">Снимите пластины и плиту скольжения.</div>					</div>				</div>				<div class="proceduralStep level1 link" id="proceduralStep_IDISE0QSAG">					<div class="title">Осмотр перед монтажом</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDKKTRPC2Y">						<div class="para p">							Осмотрите						плиту скольжения на отсутствие повреждений и загрязнений.</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDJ2DVRB0N">							<div class="para p">								При наличии загрязнений удалите их обтирочной ветошью. Сильные загрязнения удалите обтирочной ветошью, смоченной растворителем.							</div>						</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDWCZ5LZJA">							<div class="para p">								При наличии повреждений замените плиту скольжения на новую.							</div>						</div>					</div>				</div>				<div class="proceduralStep level1 link" id="proceduralStep_IDMFYTS4KO">					<div class="title">Монтаж</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDTXSVKMZ0">						<div class="para p">							Протрите резьбовые части винтов 						обтирочной ветошью, смоченной растворителем.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDAOQX40TS">						<div class="para p">							Нанесите фиксатор резьбы на винты.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDIHQQJXQC">						<div class="para p">							Установите						плиту скольжения, пластины и винты. </div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDUKPGAXV4">						<div class="para p">							Заверните винты до упора.</div>					</div>				</div>				<div class="proceduralStep level1 link" id="proceduralStep_IDPEU1NB4S">					<div class="title">Заключительные работы</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDQTUFMGQC">						<div class="para p">							Очистите зону выполнения работ и убедитесь в отсутствии посторонних предметов.						</div>					</div>				</div>			</div>			<div class="closeRqmts" id="closeRqmts_IDI2CFLGSW">				<span class="reqCondGroup formalTable" id="reqCondGroup_IDPKF3XENN"><table><caption></caption><caption class="rest"></caption><thead><tr><th colspan="3"><span class="condition"></span></th><th colspan="3"><span class="publication"></span></th></tr></thead><tbody>					<tr class="row__noConds"><td class="noConds" colspan="6"></td></tr>				</tbody></table></span>			</div>		</div>	</div></div>]]></DocumentTemplate></SimulationInteractivity>