ашня" flags="41">ICN-MTPA-A-B01000-0-MDMKD-00001-A-001-01.svg</Picture></Resources><DocumentTemplate><![CDATA[<div class="dmodule">	<div class="identAndStatusSection link" data-link="toggleStatus">		<div class="dmAddress">			<div class="dmIdent">				<div class="dmCode" data-modelIdentCode="MTPA" data-systemDiffCode="A" data-systemCode="B0" data-subSystemCode="1" data-subSubSystemCode="0" data-assyCode="00" data-disassyCode="00" data-disassyCodeVariant="A" data-infoCode="040" data-infoCodeVariant="A" data-itemLocationCode="A">MTPA-A-B0-10-00-00A-040A-A</div>				<div class="language" data-countryIsoCode="RU" data-languageIsoCode="ru"></div>				<div class="issueInfo" data-issueNumber="001" data-inWork="01"></div>			</div>			<div class="dmAddressItems">				<div class="issueDate" data-year="2025" data-month="05" data-day="30"></div>				<div class="dmTitle">					<div class="techName">Башня</div>					<div class="infoName">Описание</div>				</div>			</div>		</div>		<div class="dmStatus" data-issueType="new">			<div class="security" data-securityClassification="01"></div>			<div class="responsiblePartnerCompany" data-enterpriseCode="MDMKD">				<div class="enterpriseName">МОДУЛЬ МКД</div>			</div>			<div class="originator" data-enterpriseCode="MDMKD">				<div class="enterpriseName">МОДУЛЬ МКД</div>			</div>			<div class="applic">				<div class="displayText">					<div class="simplePara">ВСЕ</div>				</div>			</div>			<div class="brexDmRef">				<a class="dmRef  link" data-type="simple" data-actuate="onRequest" data-show="replace" data-href="URN:S1000D:DMC-S1000D-E-04-10-0301-00A-022A-D" href="S1000D-E-04-10-0301-00A-022A-D.htm"><div class="dmRefIdent">						<div class="dmCode" data-modelIdentCode="S1000D" data-systemDiffCode="E" data-systemCode="04" data-subSystemCode="1" data-subSubSystemCode="0" data-assyCode="0301" data-disassyCode="00" data-disassyCodeVariant="A" data-infoCode="022" data-infoCodeVariant="A" data-itemLocationCode="D">S1000D-E-04-10-0301-00A-022A-D</div>					</div></a>			</div>			<div class="qualityAssurance">				<div class="unverified"></div>			</div>		</div>	</div>	<div class="content">		<div class="description levels" id="description_IDXNQQQNGJ">			<div class="levelledPara level1 link" id="levelledPara_IDCWB4ZPMM">				<div class="title">Общие сведения</div>				<div class="levelledPara level2 link" id="levelledPara_IDBCBO4UCF">					<div class="title">Назначение</div>					<div class="para p">				Башня предназначена для установки и крепления крюка или другого такелажного элемента подъемного устройства, а также для балансировки траверсы в заданных условиях эксплуатации.</div>				</div>				<div class="levelledPara level2 link" id="levelledPara_IDJCMMS4J1">					<div class="title">Состав</div>					<div class="para p">В состав башни входят:<div class="randomList list  ul">							<div class="listItem li"><div class="listItemBody">								<div class="para p">стержень подвеса (1 шт.);</div>							</div></div>							<div class="listItem li"><div class="listItemBody">								<div class="para p">сварной каркас (1 шт.);</div>							</div></div>							<div class="listItem li"><div class="listItemBody">								<div class="para p">опора скольжения (4 шт.) <a class="dmRef  link" href="MTPA-A-20-12-00-00A-040A-A.htm"><div class="dmRefIdent">											<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="040" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="00" data-subSubSystemCode="2" data-subSystemCode="1" data-systemCode="20" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-20-12-00-00A-040A-A</div>										</div></a>;</div>							</div></div>							<div class="listItem li"><div class="listItemBody">								<div class="para p">опора (4 шт.) <a class="dmRef  link" href="MTPA-A-20-12-00-00A-040A-A.htm"><div class="dmRefIdent">											<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="040" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="00" data-subSubSystemCode="2" data-subSystemCode="1" data-systemCode="20" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-20-12-00-00A-040A-A</div>										</div></a>;</div>							</div></div>							<div class="listItem li"><div class="listItemBody">								<div class="para p">накладка опорная (4 шт.).</div>							</div></div>						</div>					</div>				</div>			</div>			<div class="levelledPara level1 link" id="levelledPara_IDWDFB5TM2">				<div class="title">Размещение компонентов</div>				<div class="para p">			Башня установлена в центральной части подвижной платформы  траверсы.</div>			</div>			<div class="levelledPara level1 link" id="levelledPara_IDOXJYBJ4S">				<div class="title">Описание</div>				<div class="para p">					<a class="internalRef irtt01 link" data-figure="1" data-link="link2d" data-src="ICN-MTPA-A-B01000-0-MDMKD-00001-A-001-01.cgm" title="Башня"></a>				</div>				<div class="para p">Башня представляет собой сборную конструкцию из стержня подвеса, сварного каркаса, опор и опор скольжения с возможностью перемещения в горизонтальной плоскости относительно подвижной платформы траверсы.</div>				<div class="levelledPara level2 link" id="levelledPara_IDPZI3MEER">					<div class="title">Сварной каркас</div>					<div class="para p">Сварной каркас является основным силовым элементом башни. Представляет собой сборную сварную конструкцию, состоящую из узла подвеса, перемычек, труб, замыкающих пластин, основания, рамы центрального шкафа управления (ЦШУ), уголков гидростанции, тяг перемещения башни и опорных накладок.</div>					<div class="para p">Узел подвеса предназначен для установки стержня подвеса или тензодатчика  и представляет собой сварную конструкцию, состоящую из проушин, усилительных колец и переходных пластин. На одну из проушин привариваются кронштейны для установки предохранительного штифта.</div>					<div class="para p">Четыре трубы предназначены для соединения узла подвеса и основания башни в единую конструкцию, а также для крепления рамы ЦШУ. Трубы имеют квадратное сечение, по торцам труб привариваются замыкающие пластины, предотвращающие попадание влаги, грязи и мусора. Для придания дополнительной жесткости конструкции, используются две  перемычки. Перемычки привариваются к трубам в области узла подвеса.</div>					<div class="para p">Основание предназначено для размещения гидравлического и электрического оборудования, а также для установки башни на подвижную платформу с помощью опор. Представляет собой сварную конструкцию, состоящую из продольных и поперечных балок, раскосов, уголков и соединительных пластин. Продольные балки имеют П-образную форму, обеспечивающую установку башни на подвижную платформу. В нижней части продольных балок предусмотрено крепление опор и опор скольжения <a class="dmRef  link" href="MTPA-A-20-12-00-00A-040A-A.htm"><div class="dmRefIdent">								<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="040" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="00" data-subSubSystemCode="2" data-subSystemCode="1" data-systemCode="20" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-20-12-00-00A-040A-A</div>							</div></a>. На одной из продольных балок с  внешней стороны башни приваривается кронштейн крепления дальномера. В центральной части основания приварены уголки, на которые устанавливается гидравлическая станция.</div>					<div class="para p">Рама ЦШУ предназначена для крепления центрального шкафа управления и установлена на одной из продольных балок основания с дополнительными точками крепления к трубам купола. Представляет собой сварную конструкцию, состоящую из восьми уголков разных размеров.</div>					<div class="para p">Две тяги перемещения башни предназначены для крепления штоков гидроцилиндров управления положением башни и установлены на продольных балках основания. Тяги  представляют собой сварную конструкцию, состоящую из пластин, подкосов и проушин.</div>				</div>				<div class="levelledPara level2 link" id="levelledPara_IDQOAEABOF">					<div class="title">Накладка опорная</div>					<div class="para p">В конструкции башни предусмотрено четыре опорные накладки, предназначенные для установки башни на горизонтальную поверхность при ее снятии с подвижной платформы. Накладки устанавливаются на соединительные пластины в нижней части основания.</div>				</div>				<div class="levelledPara level2 link" id="levelledPara_IDY5ADRJ0L">					<div class="title">Стержень подвеса</div>					<div class="para p">Стержень предназначен для крепления крюка или других такелажных элементов подъемного устройства. Стержень соосно устанавливается в отверстия в узле подвеса сварного каркаса, фиксируется с помощью штифта со шплинтом. Опционально стержень может быть заменен тензодатчиком <a class="dmRef  link" href="MTPA-A-D2-91-00-00A-041A-A.htm"><div class="dmRefIdent">								<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="041" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="00" data-subSubSystemCode="1" data-subSystemCode="9" data-systemCode="D2" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-D2-91-00-00A-041A-A</div>							</div></a>.</div>				</div>			</div>			<div class="figure" id="fig-001">				<div class="title">Башня</div>				<a title="Башня" class="graphic link" data-figure="1" data-infoEntityIdent="ICN-MTPA-A-B01000-0-MDMKD-00001-A-001-01" data-href="ICN-MTPA-A-B01000-0-MDMKD-00001-A-001-01.cgm" data-reproductionHeight="210mm" data-reproductionWidth="170mm" id="graphic_ID3QWRU10R" data-link="link2d" data-src="ICN-MTPA-A-B01000-0-MDMKD-00001-A-001-01.cgm">Башня</a>			</div>		</div>	</div></div>]]></DocumentTemplate></SimulationInteractivity>