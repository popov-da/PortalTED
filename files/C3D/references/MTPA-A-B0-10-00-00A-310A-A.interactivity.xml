s><DocumentTemplate><![CDATA[<div class="dmodule">	<div class="identAndStatusSection link" data-link="toggleStatus">		<div class="dmAddress">			<div class="dmIdent">				<div class="dmCode" data-modelIdentCode="MTPA" data-systemDiffCode="A" data-systemCode="B0" data-subSystemCode="1" data-subSubSystemCode="0" data-assyCode="00" data-disassyCode="00" data-disassyCodeVariant="A" data-infoCode="310" data-infoCodeVariant="A" data-itemLocationCode="A">MTPA-A-B0-10-00-00A-310A-A</div>				<div class="language" data-countryIsoCode="RU" data-languageIsoCode="ru"></div>				<div class="issueInfo" data-issueNumber="001" data-inWork="01"></div>			</div>			<div class="dmAddressItems">				<div class="issueDate" data-year="2025" data-month="05" data-day="30"></div>				<div class="dmTitle">					<div class="techName">Башня</div>					<div class="infoName">Визуальный осмотр</div>				</div>			</div>		</div>		<div class="dmStatus" data-issueType="new">			<div class="security" data-securityClassification="01"></div>			<div class="responsiblePartnerCompany" data-enterpriseCode="MDMKD">				<div class="enterpriseName">МОДУЛЬ МКД</div>			</div>			<div class="originator" data-enterpriseCode="MDMKD">				<div class="enterpriseName">МОДУЛЬ МКД</div>			</div>			<div class="applic">				<div class="displayText">					<div class="simplePara">ВСЕ</div>				</div>			</div>			<div class="brexDmRef">				<a class="dmRef  link" data-type="simple" data-actuate="onRequest" data-show="replace" data-href="URN:S1000D:DMC-S1000D-E-04-10-0301-00A-022A-D" href="S1000D-E-04-10-0301-00A-022A-D.htm"><div class="dmRefIdent">						<div class="dmCode" data-modelIdentCode="S1000D" data-systemDiffCode="E" data-systemCode="04" data-subSystemCode="1" data-subSubSystemCode="0" data-assyCode="0301" data-disassyCode="00" data-disassyCodeVariant="A" data-infoCode="022" data-infoCodeVariant="A" data-itemLocationCode="D">S1000D-E-04-10-0301-00A-022A-D</div>					</div></a>			</div>			<div class="qualityAssurance">				<div class="unverified"></div>			</div>		</div>	</div>	<div class="content">		<div class="procedure">			<div class="preliminaryRqmts" id="preliminaryRqmts_IDCOZVBE40">				<span class="reqCondGroup formalTable" id="reqCondGroup_IDGETI3MNG"><table><caption></caption><caption class="rest"></caption><thead><tr><th colspan="3"><span class="condition"></span></th><th colspan="3"><span class="publication"></span></th></tr></thead><tbody>					<tr class="row__noConds"><td class="noConds" colspan="6"></td></tr>				</tbody></table></span>				<span class="reqSupportEquips prelimTable formalTable" id="reqSupportEquips_IDAKVHTULY"><table><caption></caption><caption class="rest"></caption><thead><tr><th class="prelimTable__name"></th><th class="prelimTable__identification"></th><th class="prelimTable__qty"></th><th class="prelimTable__remark"></th></tr></thead><tbody>					<tr class="supportEquipDescr"><td><div><div class="name">Шаблоны сварщика универсальные</div></div></td><td class="prelimTable_identification"><div class="identNumber" data-partNumber="УШС-3"></div></td><td><div class="reqQuantity" data-unitOfMeasure="шт.">1 шт.</div></td><td></td></tr>				</tbody></table></span>				<span class="reqSupplies prelimTable formalTable" id="reqSupplies_IDDMJZX2U1"><table><caption></caption><caption class="rest"></caption><thead><tr><th class="prelimTable__name"></th><th class="prelimTable__identification"></th><th class="prelimTable__qty"></th><th class="prelimTable__remark"></th></tr></thead><tbody>					<tr class="supplyDescr"><td><div><div class="name">Ветошь обтирочная</div></div></td><td class="prelimTable_identification"><div class="supplyRef" data-supplyNumber="ТУ 8189-018-01877509-2001" data-supplyNumberType="sp01">ТУ 8189-018-01877509-2001</div></td><td><div class="reqQuantity"></div></td><td></td></tr><tr class="supplyDescr"><td><div><div class="name">Растворитель</div></div></td><td class="prelimTable_identification"><div class="supplyRef" data-supplyNumber="Нефрас-С-50/170 ГОСТ 8505-80" data-supplyNumberType="sp01">Нефрас-С-50/170 ГОСТ 8505-80</div></td><td><div class="reqQuantity"></div></td><td></td></tr><tr class="supplyDescr"><td><div><div class="name">Спирт этиловый ректификованный</div></div></td><td class="prelimTable_identification"><div class="supplyRef" data-supplyNumber="ГОСТ Р 55878-2013" data-supplyNumberType="sp01">ГОСТ Р 55878-2013</div></td><td><div class="reqQuantity"></div></td><td></td></tr>				</tbody></table></span>				<span class="reqSpares prelimTable formalTable" id="reqSpares_IDK1OEUQZU"><table><caption></caption><caption class="rest"></caption><thead><tr><th class="prelimTable__name"></th><th class="prelimTable__identification"></th><th class="prelimTable__qty"></th><th class="prelimTable__remark"></th></tr></thead><tbody>					<tr class="row__noSpares"><td class="noSpares" colspan="4"></td></tr>				</tbody></table></span>				<div class="reqSafety">					<div class="safetyRqmts">						<div><div class="warning" id="wrn-001">							<div class="warningAndCautionPara p">РАБОТЫ ВЫПОЛНЯТЬ НА ОБЕСТОЧЕННОМ ОБОРУДОВАНИИ.</div>						</div></div>					</div>				</div>			</div>			<div><div class="mainProcedure" id="mainProcedure_IDC4PDMOTM"></div></div><div class="Procedure levels" id="">				<div class="proceduralStep level1 link" id="proceduralStep_IDYVFHO0TR">					<div class="title">Подготовительные работы</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDICFW2UVK">						<div class="para p">Выполните спуск траверсы <a class="dmRef  link" href="MTPA-A-07-10-00-00A-176A-A.htm"><div class="dmRefIdent">									<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="176" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="00" data-subSubSystemCode="0" data-subSystemCode="1" data-systemCode="07" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-07-10-00-00A-176A-A</div>								</div></a>.</div>					</div>				</div>				<div class="proceduralStep level1 link" id="proceduralStep_IDZXYGLFS5">					<div class="title">Осмотр</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDI2L4U231">						<div class="title">Осмотр сварного каркаса</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDTFCMNE5K">							<div class="para p">Осмотрите сварной каркас на отсутствие загрязнений.</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDXLV3ESMZ">								<div class="para p">При наличии загрязнений удалите их обтирочной ветошью. Сильные загрязнения удалитеобтирочной ветошью, смоченной растворителем.</div>							</div>						</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDLOHRVTQB">							<div class="para p">Осмотрите сварные швы. Убедитесь, что сварные швы не имеют следующихповерхностных дефектов:<div class="randomList list  ul">									<div class="listItem li"><div class="listItemBody">										<div class="para p">трещин, расположенных в металле шва, по линиисплавления и в околошовной зоне основного металла;</div>									</div></div>									<div class="listItem li"><div class="listItemBody">										<div class="para p">свищей и пористости наружной поверхности шва;</div>									</div></div>									<div class="listItem li"><div class="listItemBody">										<div class="para p">подрезов глубиной более 0,5 мм;</div>									</div></div>									<div class="listItem li"><div class="listItemBody">										<div class="para p">наплывов общей длиной более 10 % от длины участка шва;</div>									</div></div>									<div class="listItem li"><div class="listItemBody">										<div class="para p">пор, расположенных в виде сплошной сетки;</div>									</div></div>									<div class="listItem li"><div class="listItemBody">										<div class="para p">прожогов, незаваренных кратеров, свищей;</div>									</div></div>									<div class="listItem li"><div class="listItemBody">										<div class="para p">отклонений по геометрическим размерам и взаимному расположению свариваемыхэлементов;</div>									</div></div>									<div class="listItem li"><div class="listItemBody">										<div class="para p">дефектов на поверхности основного металла и сварных соединений (вмятин,расслоений, раковин, непроваров, включений).</div>									</div></div>								</div>							</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDLEC0CAP0">								<div class="para p">В случае обнаружения дефектов прекратите использование траверсыдо устранения дефектов. В случае невозможности устранения обнаруженных дефектоввыведите траверсу из эксплуатации.</div>							</div>						</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDV0OX32PA">							<div class="para p">Убедитесь, что ЛКП на сварном каркасе не повреждено.</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDULQIND3R">								<div class="para p">В случае повреждения ЛКП восстановите его <a class="dmRef  link" href="MTPM-A-20-21-03-00A-257A-A.htm"><div class="dmRefIdent">											<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="257" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="03" data-subSubSystemCode="1" data-subSystemCode="2" data-systemCode="20" data-systemDiffCode="A" data-modelIdentCode="MTPM">MTPM-A-20-21-03-00A-257A-A</div>										</div></a>.</div>							</div>						</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDTNGHWFSD">						<div class="title">Осмотр опоры скольжения</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDXZHU3BY5">							<div class="para p">Осмотрите опору скольжения на отсутствие загрязнений.</div>							<div class="proceduralStep level4 link" id="proceduralStep_ID3SEKT534">								<div class="para p">При наличии загрязнений удалите их обтирочной ветошью. Сильные загрязнения удалитеобтирочной ветошью, смоченной растворителем.</div>							</div>						</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDJFRTZ5M5">							<div class="para p">Осмотрите опору скольжения на отсутствие трещин, деформаций, разрушений и других механических повреждений.</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDQXUNII22">								<div class="para p">При необходимости выполните замену  опоры скольжения <a class="dmRef  link" href="MTPA-A-20-12-02-00A-922A-A.htm"><div class="dmRefIdent">											<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="922" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="02" data-subSubSystemCode="2" data-subSystemCode="1" data-systemCode="20" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-20-12-02-00A-922A-A</div>										</div></a>.</div>							</div>						</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDARWMAMM1">							<div class="para p">Убедитесь в надежности крепления опоры скольжения.</div>							<div class="proceduralStep level4 link" id="proceduralStep_ID3CFJWVR5">								<div class="para p">При необходимости затяните слабо затянутые крепежные элементы.</div>							</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDUWSZDVE3">								<div class="para p">При необходимости установите на свои места недостающие крепежные элементы.</div>							</div>						</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDB100EKGU">							<div class="para p">Убедитесь в отсутствии механических повреждений на крепежных элементах.</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDCCBXTTQE">								<div class="para p">При необходимости замените поврежденные крепежные элементы на новые.</div>							</div>						</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDPECDHKHQ">							<div class="para p">Осмотрите сварные швы. Убедитесь, что сварные швы не имеют следующихповерхностных дефектов:<div class="randomList list  ul">									<div class="listItem li"><div class="listItemBody">										<div class="para p">трещин, расположенных в металле шва, по линиисплавления и в околошовной зоне основного металла;</div>									</div></div>									<div class="listItem li"><div class="listItemBody">										<div class="para p">свищей и пористости наружной поверхности шва;</div>									</div></div>									<div class="listItem li"><div class="listItemBody">										<div class="para p">подрезов глубиной более 0,5 мм;</div>									</div></div>									<div class="listItem li"><div class="listItemBody">										<div class="para p">наплывов общей длиной более 10 % от длины участка шва;</div>									</div></div>									<div class="listItem li"><div class="listItemBody">										<div class="para p">пор, расположенных в виде сплошной сетки;</div>									</div></div>									<div class="listItem li"><div class="listItemBody">										<div class="para p">прожогов, незаваренных кратеров, свищей;</div>									</div></div>									<div class="listItem li"><div class="listItemBody">										<div class="para p">отклонений по геометрическим размерам и взаимному расположению свариваемыхэлементов;</div>									</div></div>									<div class="listItem li"><div class="listItemBody">										<div class="para p">дефектов на поверхности основного металла и сварных соединений (вмятин,расслоений, раковин, непроваров, включений).</div>									</div></div>								</div>							</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDI41E3ZLA">								<div class="para p">В случае обнаружения дефектов при необходимости прекратите использование траверсыдо устранения дефектов. В случае невозможности устранения обнаруженных дефектоввыведите траверсу из эксплуатации.</div>							</div>						</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDCT0COTX5">							<div class="para p">Убедитесь, что ЛКП на опоре скольжения не повреждено.</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDMDMAY2FH">								<div class="para p">В случае повреждения ЛКП восстановите его <a class="dmRef  link" href="MTPM-A-20-21-03-00A-257A-A.htm"><div class="dmRefIdent">											<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="257" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="03" data-subSubSystemCode="1" data-subSystemCode="2" data-systemCode="20" data-systemDiffCode="A" data-modelIdentCode="MTPM">MTPM-A-20-21-03-00A-257A-A</div>										</div></a>.</div>							</div>						</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDVTHGQ2D2">							<div class="para p">Повторите вышеуказанные процедуры для других опор скольжения.</div>						</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_ID05MTJZZ3">						<div class="title">Осмотр опор</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDALFYCHAN">							<div class="para p">Осмотрите опору  на отсутствие загрязнений.</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDNWNUOW3A">								<div class="para p">При наличии загрязнений удалите их обтирочной ветошью. Сильные загрязнения удалитеобтирочной ветошью, смоченной спиртом.</div>							</div>						</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDZCHWC44N">							<div class="para p">Осмотрите опору на отсутствие трещин, разрывов и других механических повреждений.</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDVABWE45X">								<div class="para p">При необходимости выполните замену  опоры <a class="dmRef  link" href="MTPA-A-20-12-04-00A-921A-A.htm"><div class="dmRefIdent">											<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="921" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="04" data-subSubSystemCode="2" data-subSystemCode="1" data-systemCode="20" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-20-12-04-00A-921A-A</div>										</div></a>.</div>							</div>						</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDI22UFWVU">							<div class="para p">Убедитесь в надежности крепления опоры.</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDC3VAMHYL">								<div class="para p">При необходимости затяните слабо затянутые крепежные элементы.</div>							</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDPMZGA3T2">								<div class="para p">При необходимости установите на свои места недостающие крепежные элементы.</div>							</div>						</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDQE0UD1DD">							<div class="para p">Убедитесь в отсутствии механических повреждений на крепежных элементах.</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDBIQXURUO">								<div class="para p">При необходимости замените поврежденные крепежные элементы на новые.</div>							</div>						</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDTATIEJCF">							<div class="para p">Повторите вышеуказанные процедуры для других опор.</div>						</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_ID5TUAXOYR">						<div class="title">Осмотр тензодатчика</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDXJRSYIXB">							<div class="para p">Осмотрите тензодатчик <a class="dmRef  link" href="MTPA-A-D2-91-04-00A-310A-A.htm"><div class="dmRefIdent">										<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="310" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="04" data-subSubSystemCode="1" data-subSystemCode="9" data-systemCode="D2" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-D2-91-04-00A-310A-A</div>									</div></a>.</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDSQM02YNB">								<div class="para p">При необходимости выполните замену  тензодатчика <a class="dmRef  link" href="MTPA-A-D2-91-04-00A-922A-A.htm"><div class="dmRefIdent">											<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="922" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="04" data-subSubSystemCode="1" data-subSystemCode="9" data-systemCode="D2" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-D2-91-04-00A-922A-A</div>										</div></a>.</div>							</div>						</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_ID0D2TBWJJ">						<div class="title">Осмотр электрооборудования</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDIQGZDF3O">							<div class="para p">Осмотрите ШУ № 1 <a class="dmRef  link" href="MTPA-A-D2-71-00-00A-310A-A.htm"><div class="dmRefIdent">										<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="310" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="00" data-subSubSystemCode="1" data-subSystemCode="7" data-systemCode="D2" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-D2-71-00-00A-310A-A</div>									</div></a>.</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDI0WQK23L">								<div class="para p">При необходимости выполните замену ШУ № 1 <a class="dmRef  link" href="MTPA-A-D2-71-00-00A-922A-A.htm"><div class="dmRefIdent">											<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="922" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="00" data-subSubSystemCode="1" data-subSystemCode="7" data-systemCode="D2" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-D2-71-00-00A-922A-A</div>										</div></a>.</div>							</div>						</div>						<div class="proceduralStep level3 link" id="proceduralStep_ID1LCZQ0QD">							<div class="para p">Осмотрите лазерный дальномер <a class="dmRef  link" href="MTPA-A-D2-91-03-00A-311A-A.htm"><div class="dmRefIdent">										<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="311" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="03" data-subSubSystemCode="1" data-subSystemCode="9" data-systemCode="D2" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-D2-91-03-00A-311A-A</div>									</div></a>.</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDFXIKYVC2">								<div class="para p">При необходимости выполните замену лазерного дальномера <a class="dmRef  link" href="MTPA-A-D2-91-03-00A-922A-A.htm"><div class="dmRefIdent">											<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="922" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="03" data-subSubSystemCode="1" data-subSystemCode="9" data-systemCode="D2" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-D2-91-03-00A-922A-A</div>										</div></a>.</div>							</div>						</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDB02S0FFW">							<div class="para p">Осмотрите антенну Wi-Fi  <a class="dmRef  link" href="MTPA-A-E1-60-02-00A-311A-A.htm"><div class="dmRefIdent">										<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="311" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="02" data-subSubSystemCode="0" data-subSystemCode="6" data-systemCode="E1" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-E1-60-02-00A-311A-A</div>									</div></a>.</div>							<div class="proceduralStep level4 link" id="proceduralStep_ID5R1REALX">								<div class="para p">При необходимости выполните замену антенны Wi-Fi <a class="dmRef  link" href="MTPA-A-E1-60-02-00A-922A-A.htm"><div class="dmRefIdent">											<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="922" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="02" data-subSubSystemCode="0" data-subSystemCode="6" data-systemCode="E1" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-E1-60-02-00A-922A-A</div>										</div></a>.</div>							</div>						</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDRG1LNC4A">							<div class="para p">Осмотрите светодиодные прожекторы башни <a class="dmRef  link" href="MTPA-A-D2-40-02-00A-310A-A.htm"><div class="dmRefIdent">										<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="310" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="02" data-subSubSystemCode="0" data-subSystemCode="4" data-systemCode="D2" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-D2-40-02-00A-310A-A</div>									</div></a>.</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDGMBDJXPU">								<div class="para p">При необходимости выполните замену светодиодного прожектора башни <a class="dmRef  link" href="MTPA-A-D2-40-02-00A-922A-A.htm"><div class="dmRefIdent">											<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="922" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="02" data-subSubSystemCode="0" data-subSystemCode="4" data-systemCode="D2" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-D2-40-02-00A-922A-A</div>										</div></a>.</div>							</div>						</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_ID4W4M2R34">						<div class="title">Осмотр гидравлического оборудования</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDOHPVEALI">							<div class="para p">Осмотрите гидравлическую станцию <a class="dmRef  link" href="MTPA-A-K1-11-00-00A-310A-A.htm"><div class="dmRefIdent">										<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="310" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="00" data-subSubSystemCode="1" data-subSystemCode="1" data-systemCode="K1" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-K1-11-00-00A-310A-A</div>									</div></a>.</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDG252EV5G">								<div class="para p">При необходимости выполните замену  гидравлической станции <a class="dmRef  link" href="MTPA-A-K1-11-00-00A-922A-A.htm"><div class="dmRefIdent">											<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="922" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="00" data-subSubSystemCode="1" data-subSystemCode="1" data-systemCode="K1" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-K1-11-00-00A-922A-A</div>										</div></a>.</div>							</div>						</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDCFKHBG10">							<div class="para p">Осмотрите гидравлические соединители на остутсвие 					загрязнений.</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDWYKYVZWX">								<div class="para p">При наличии загрязнений удалите их обтирочной ветошью. Сильные загрязнения удалитеобтирочной ветошью, смоченной спиртом.</div>							</div>						</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDDIWVDOGE">							<div class="para p">Осмотрите гидравлические соединители на отсутствие трещин, других механических повреждений и отсутствие течей.</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDXVZ4HNBV">								<div class="para p">При необходимости выполните замену  гидравлических соединителей.</div>							</div>						</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDWXG2TWC0">							<div class="para p">Убедитесь в надежности крепления штоков гидроцилиндров управления башни.</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDVHHTMZHB">								<div class="para p">При необходимости затяните слабо затянутые крепежные элементы.</div>							</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDFWQU3ONR">								<div class="para p">При необходимости установите на свои места недостающие крепежные элементы.</div>							</div>						</div>						<div class="proceduralStep level3 link" id="proceduralStep_ID1ZDLDPDP">							<div class="para p">Убедитесь в отсутствии механических повреждений на крепежных элементах.</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDFFQFUM1N">								<div class="para p">При необходимости замените поврежденные крепежные элементы на новые.</div>							</div>						</div>					</div>				</div>				<div class="proceduralStep level1 link" id="proceduralStep_IDNAEP4JI0">					<div class="title">Заключительные работы</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDWAJBFTPH">						<div class="para p">Очистите зону выполнения работ и убедитесь в отсутствии посторонних предметов.</div>					</div>				</div>			</div>			<div class="closeRqmts" id="closeRqmts_IDFI2KAA3B">				<span class="reqCondGroup formalTable" id="reqCondGroup_IDAOPP4AJM"><table><caption></caption><caption class="rest"></caption><thead><tr><th colspan="3"><span class="condition"></span></th><th colspan="3"><span class="publication"></span></th></tr></thead><tbody>					<tr class="row__noConds"><td class="noConds" colspan="6"></td></tr>				</tbody></table></span>			</div>		</div>	</div></div>]]></DocumentTemplate></SimulationInteractivity>