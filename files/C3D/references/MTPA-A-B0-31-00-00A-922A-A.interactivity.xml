ass="identAndStatusSection link" data-link="toggleStatus">		<div class="dmAddress">			<div class="dmIdent">				<div class="dmCode" data-modelIdentCode="MTPA" data-systemDiffCode="A" data-systemCode="B0" data-subSystemCode="3" data-subSubSystemCode="1" data-assyCode="00" data-disassyCode="00" data-disassyCodeVariant="A" data-infoCode="922" data-infoCodeVariant="A" data-itemLocationCode="A">MTPA-A-B0-31-00-00A-922A-A</div>				<div class="language" data-countryIsoCode="RU" data-languageIsoCode="ru"></div>				<div class="issueInfo" data-issueNumber="001" data-inWork="01"></div>			</div>			<div class="dmAddressItems">				<div class="issueDate" data-year="2025" data-month="05" data-day="30"></div>				<div class="dmTitle">					<div class="techName">Телескоп большой</div>					<div class="infoName">Демонтаж и монтаж</div>				</div>			</div>		</div>		<div class="dmStatus" data-issueType="new">			<div class="security" data-securityClassification="01"></div>			<div class="responsiblePartnerCompany" data-enterpriseCode="MDMKD">				<div class="enterpriseName">МОДУЛЬ МКД</div>			</div>			<div class="originator" data-enterpriseCode="MDMKD">				<div class="enterpriseName">МОДУЛЬ МКД</div>			</div>			<div class="applic">				<div class="displayText">					<div class="simplePara">ВСЕ</div>				</div>			</div>			<div class="brexDmRef">				<a class="dmRef  link" data-type="simple" data-actuate="onRequest" data-show="replace" data-href="URN:S1000D:DMC-S1000D-E-04-10-0301-00A-022A-D" href="S1000D-E-04-10-0301-00A-022A-D.htm"><div class="dmRefIdent">						<div class="dmCode" data-modelIdentCode="S1000D" data-systemDiffCode="E" data-systemCode="04" data-subSystemCode="1" data-subSubSystemCode="0" data-assyCode="0301" data-disassyCode="00" data-disassyCodeVariant="A" data-infoCode="022" data-infoCodeVariant="A" data-itemLocationCode="D">S1000D-E-04-10-0301-00A-022A-D</div>					</div></a>			</div>			<div class="qualityAssurance">				<div class="unverified"></div>			</div>		</div>	</div>	<div class="content">		<div class="procedure">			<div class="preliminaryRqmts" id="preliminaryRqmts_IDP0LUA2JK">				<span class="reqCondGroup formalTable" id="reqCondGroup_IDSEGGFC2H"><table><caption></caption><caption class="rest"></caption><thead><tr><th colspan="3"><span class="condition"></span></th><th colspan="3"><span class="publication"></span></th></tr></thead><tbody>					<tr class="row__noConds"><td class="noConds" colspan="6"></td></tr>				</tbody></table></span>				<span class="reqSupportEquips prelimTable formalTable" id="reqSupportEquips_ID3K0QPGV2"><table><caption></caption><caption class="rest"></caption><thead><tr><th class="prelimTable__name"></th><th class="prelimTable__identification"></th><th class="prelimTable__qty"></th><th class="prelimTable__remark"></th></tr></thead><tbody>					<tr class="row__noSupportEquips"><td class="noSupportEquips" colspan="4"></td></tr>				</tbody></table></span>				<span class="reqSupplies prelimTable formalTable" id="reqSupplies_IDUOJQBHEC"><table><caption></caption><caption class="rest"></caption><thead><tr><th class="prelimTable__name"></th><th class="prelimTable__identification"></th><th class="prelimTable__qty"></th><th class="prelimTable__remark"></th></tr></thead><tbody>					<tr class="supplyDescr"><td><div><div class="name">Ветошь обтирочная</div></div></td><td class="prelimTable_identification"><div class="supplyRef" data-supplyNumber="ГОСТ 4643-75" data-supplyNumberType="sp01">ГОСТ 4643-75</div></td><td><div class="reqQuantity"></div></td><td></td></tr><tr class="supplyDescr"><td><div><div class="name">Растворитель</div></div></td><td class="prelimTable_identification"><div class="supplyRef" data-supplyNumber="Нефрас-С-50/170 ГОСТ 8505-80" data-supplyNumberType="sp01">Нефрас-С-50/170 ГОСТ 8505-80</div></td><td><div class="reqQuantity"></div></td><td></td></tr>				</tbody></table></span>				<span class="reqSpares prelimTable formalTable" id="reqSpares_ID3V4LUTKO"><table><caption></caption><caption class="rest"></caption><thead><tr><th class="prelimTable__name"></th><th class="prelimTable__identification"></th><th class="prelimTable__qty"></th><th class="prelimTable__remark"></th></tr></thead><tbody>					<tr class="row__noSpares"><td class="noSpares" colspan="4"></td></tr>				</tbody></table></span>				<div class="reqSafety">					<div class="safetyRqmts">						<div><div class="warning" id="wrn-001">							<div class="warningAndCautionPara p">РАБОТЫ ВЫПОЛНЯТЬ БЕЗ УСТАНОВЛЕННОГО ГРУЗА.</div>							<div class="warningAndCautionPara p">РАБОТЫ ВЫПОЛНЯТЬ НА ОБЕСТОЧЕННОМ ОБОРУДОВАНИИ.</div>						</div></div>					</div>				</div>			</div>			<div><div class="mainProcedure" id="mainProcedure_IDTFOMGJ00"></div></div><div class="Procedure levels" id="">				<div class="proceduralStep level1 link" id="proceduralStep_IDCL3Y0O4A">					<div class="title">Подготовительные работы</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDREJKPOEB">						<div class="para p">Выполните спуск траверсы <a class="dmRef  link" href="MTPA-A-07-10-00-00A-176A-A.htm"><div class="dmRefIdent">									<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="176" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="00" data-subSubSystemCode="0" data-subSystemCode="1" data-systemCode="07" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-07-10-00-00A-176A-A</div>								</div></a>.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_ID2YQ53UB1">						<div class="para p">Демонтируйте малые телескопы <a class="dmRef  link" href="MTPA-A-B0-32-00-00A-922A-A.htm"><div class="dmRefIdent">									<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="922" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="00" data-subSubSystemCode="2" data-subSystemCode="3" data-systemCode="B0" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-B0-32-00-00A-922A-A</div>								</div></a>.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDEWK3V1KU">						<div class="para p">Демонтируйте гидроцилиндры <a class="dmRef  link" href="MTPA-A-K1-30-04-00A-922A-A.htm"><div class="dmRefIdent">									<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="922" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="04" data-subSubSystemCode="0" data-subSystemCode="3" data-systemCode="K1" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-K1-30-04-00A-922A-A</div>								</div></a>.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDMJIOII0W">						<div class="para p">Демонтируйте лотки кабель-каналов и кабель-каналы <a class="dmRef  link" href="MTPA-A-B0-31-01-00A-922A-A.htm"><div class="dmRefIdent">									<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="922" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="01" data-subSubSystemCode="1" data-subSystemCode="3" data-systemCode="B0" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-B0-31-01-00A-922A-A</div>								</div></a>.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDH0RRH00R">						<div class="para p">Демонтируйте блок распределителей телескопов и замков <a class="dmRef  link" href="MTPA-A-K1-20-03-00A-922A-A.htm"><div class="dmRefIdent">									<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="922" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="03" data-subSubSystemCode="0" data-subSystemCode="2" data-systemCode="K1" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-K1-20-03-00A-922A-A</div>								</div></a>.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_ID3VAVRRDZ">						<div class="para p">Демонтируйте гидрозамки <a class="dmRef  link" href="MTPA-A-K1-20-03-00A-922A-A.htm"><div class="dmRefIdent">									<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="922" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="03" data-subSubSystemCode="0" data-subSystemCode="2" data-systemCode="K1" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-K1-20-03-00A-922A-A</div>								</div></a>.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDD1CSV0LZ">						<div class="para p">Демонтируйте шкаф управления <a class="dmRef  link" href="MTPA-A-D2-72-00-00A-922A-A.htm"><div class="dmRefIdent">									<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="922" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="00" data-subSubSystemCode="2" data-subSystemCode="7" data-systemCode="D2" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-D2-72-00-00A-922A-A</div>								</div></a>.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_ID0NLI5UFZ">						<div class="para p">Демонтируйте лазерный дальномер <a class="dmRef  link" href="MTPA-A-D2-91-03-00A-922A-A.htm"><div class="dmRefIdent">									<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="922" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="03" data-subSubSystemCode="1" data-subSystemCode="9" data-systemCode="D2" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-D2-91-03-00A-922A-A</div>								</div></a>.</div>					</div>				</div>				<div class="proceduralStep level1 link" id="proceduralStep_IDIAK2EWTZ">					<div class="title">Демонтаж</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDADRY45US">						<div class="para p">Отверните болты 						крепления колодок.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDZCYDQ4QQ">						<div class="para p">Снимите болты, трубопроводы, 						металлические пластины и зажимы колодок.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDCE52EBJ4">						<div class="para p">Снимите трубопроводы.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDEPOMWBT3">						<div class="para p">Установите технологические заглушки на трубопроводы.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDTAGHPH5G">						<div class="para p">Удалите стопорение и снимите шплинт.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDY2Y5LNRI">						<div class="para p">Снимите шайбу, ось из кронштейна большого телескопа и уха 						гидроцилиндра.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_ID1O0U5EEZ">						<div class="para p">Отверните ниппелей  от розеток БРС.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDV5B0AYBX">						<div class="para p">Установите технологические заглушки на ниппели и розетки БРС.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDSSZTTJUB">						<div class="para p">Зафиксируйте винты и отверните гайки.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDRU3FJ4SW">						<div class="para p">Снимите винты, шайбы, кабель-канал с кронштейна.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDBC55IBT5">						<div class="para p">Выполните строповку большого телескопа.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDSA2VULSQ">						<div class="para p">Извлеките большой телескоп из центральной рамы.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDQYJMIVLG">						<div class="para p">Демонтируйте плиты скольжения <a class="dmRef  link" href="MTPA-A-20-12-01-00A-922A-A.htm"><div class="dmRefIdent">									<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="922" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="01" data-subSubSystemCode="2" data-subSystemCode="1" data-systemCode="20" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-20-12-01-00A-922A-A</div>								</div></a>.</div>					</div>				</div>				<div class="proceduralStep level1 link" id="proceduralStep_IDKU04JBAC">					<div class="title">Осмотр перед монтажом</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDFEQD1QVI">						<div class="para p">Осмотрите большой телескоп на отсутствие загрязнений, сколов, трещин и других механических повреждений.</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDGM4QBTHM">							<div class="para p">При наличии загрязнений удалите их обтирочной ветошью. Сильные загрязнения удалите обтирочной ветошью, смоченной растворителем.</div>						</div>						<div class="proceduralStep level3 link" id="proceduralStep_ID4AQVVMZ3">							<div class="para p">При наличии повреждений замените		 большой телескоп на новый.</div>						</div>					</div>				</div>				<div class="proceduralStep level1 link" id="proceduralStep_IDEWSEGVQB">					<div class="title">Монтаж</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDZOHXRID4">						<div class="para p">Установите плиты скольжения <a class="dmRef  link" href="MTPA-A-20-12-01-00A-922A-A.htm"><div class="dmRefIdent">									<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="922" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="01" data-subSubSystemCode="2" data-subSystemCode="1" data-systemCode="20" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-20-12-01-00A-922A-A</div>								</div></a>.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_ID525T0YVE">						<div class="para p">Установите большой телескоп в центральную раму.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDSA4AU0E0">						<div class="para p">Установите 						кабель-канал, совместив с отверстиями в кронштейне.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDABDN0MMK">						<div class="para p">Установите шайбы и винты.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDG4KUUUUM">						<div class="para p">Зафиксируйте винты и заверните гайки до упора.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDXWXT2SCI">						<div class="para p">Снимите технологические заглушки с ниппелей и розеток БРС.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDBXORVU3A">						<div class="para p">Установите и заверните ниппель в розетки БРС.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_ID1VXWXUSI">						<div class="para p">Установите ухо гидроцилиндра в кронштейн большого телескопа.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDSMGQFRE0">						<div class="para p">Установите ось в ухо гидроцилиндра и кронштейн большого телескопа.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDXOU3TJAM">						<div class="para p">Установите шайбу и шплинт.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDCR4L5C0H">						<div class="para p">Установите ось в кронштейн малого телескопа и ухо гидроцилиндра.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDOGFOQALJ">						<div class="para p">Выполните стопорение.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDXKQZVVRY">						<div class="para p">Снимите технологические заглушки с трубопроводов.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_ID2YAK2PMQ">						<div class="para p">Подключите трубопроводы к их ответным частям.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDEZEFVOBD">						<div class="para p">Установите трубопроводы в колодки.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDJZEBPJ2C">						<div class="para p">Установите зажимы колодок, металлические пластины на колодки.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDOKM1MK1J">						<div class="para p">Установите и заверните болты до упора.</div>					</div>				</div>				<div class="proceduralStep level1 link" id="proceduralStep_IDYQTSCNZS">					<div class="title">Заключительные работы</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDXOVHZM4J">						<div class="para p">Установите лотки кабель-каналов и кабель-каналы <a class="dmRef  link" href="MTPA-A-B0-31-01-00A-922A-A.htm"><div class="dmRefIdent">									<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="922" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="01" data-subSubSystemCode="1" data-subSystemCode="3" data-systemCode="B0" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-B0-31-01-00A-922A-A</div>								</div></a>.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDZUS3PKTF">						<div class="para p">Установите лазерный дальномер <a class="dmRef  link" href="MTPA-A-D2-91-03-00A-922A-A.htm"><div class="dmRefIdent">									<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="922" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="03" data-subSubSystemCode="1" data-subSystemCode="9" data-systemCode="D2" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-D2-91-03-00A-922A-A</div>								</div></a>.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDMUNSI15H">						<div class="para p">Установите шкаф управления <a class="dmRef  link" href="MTPA-A-D2-72-00-00A-922A-A.htm"><div class="dmRefIdent">									<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="922" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="00" data-subSubSystemCode="2" data-subSystemCode="7" data-systemCode="D2" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-D2-72-00-00A-922A-A</div>								</div></a>.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDBUQTIQH5">						<div class="para p">Установите гидрозамки <a class="dmRef  link" href="MTPA-A-K1-20-03-00A-922A-A.htm"><div class="dmRefIdent">									<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="922" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="03" data-subSubSystemCode="0" data-subSystemCode="2" data-systemCode="K1" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-K1-20-03-00A-922A-A</div>								</div></a>.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDHJRSN1DM">						<div class="para p">Установите блок распределителей телескопов и замков <a class="dmRef  link" href="MTPA-A-K1-20-03-00A-922A-A.htm"><div class="dmRefIdent">									<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="922" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="03" data-subSubSystemCode="0" data-subSystemCode="2" data-systemCode="K1" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-K1-20-03-00A-922A-A</div>								</div></a>.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDDZXE3513">						<div class="para p">Установите малые телескопы <a class="dmRef  link" href="MTPA-A-B0-32-00-00A-922A-A.htm"><div class="dmRefIdent">									<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="922" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="00" data-subSubSystemCode="2" data-subSystemCode="3" data-systemCode="B0" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-B0-32-00-00A-922A-A</div>								</div></a>.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDKXGLAQJ1">						<div class="para p">Установите гидроцилиндры <a class="dmRef  link" href="MTPA-A-K1-30-04-00A-922A-A.htm"><div class="dmRefIdent">									<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="922" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="04" data-subSubSystemCode="0" data-subSystemCode="3" data-systemCode="K1" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-K1-30-04-00A-922A-A</div>								</div></a>.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDOWKM4JPP">						<div class="para p">Очистите зону выполнения работ и убедитесь в отсутствии посторонних предметов.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_ID1EQENVMX">						<div class="para p">Выполните дозаправку гидравлической системы <a class="dmRef  link" href="MTPA-A-12-11-00-00A-210A-A.htm"><div class="dmRefIdent">									<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="210" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="00" data-subSubSystemCode="1" data-subSystemCode="1" data-systemCode="12" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-12-11-00-00A-210A-A</div>								</div></a>.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDLHSXYCPK">						<div class="para p">Произведите  		 функциональные испытания гидравлической системы <a class="dmRef  link" href="MTPA-A-K1-10-00-00A-340A-A.htm"><div class="dmRefIdent">									<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="340" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="00" data-subSubSystemCode="0" data-subSystemCode="1" data-systemCode="K1" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-K1-10-00-00A-340A-A</div>								</div></a>						</div>					</div>				</div>			</div>			<div class="closeRqmts" id="closeRqmts_IDTXYQNZJO">				<span class="reqCondGroup formalTable" id="reqCondGroup_IDMDACD2V2"><table><caption></caption><caption class="rest"></caption><thead><tr><th colspan="3"><span class="condition"></span></th><th colspan="3"><span class="publication"></span></th></tr></thead><tbody>					<tr class="row__noConds"><td class="noConds" colspan="6"></td></tr>				</tbody></table></span>			</div>		</div>	</div></div>]]></DocumentTemplate></SimulationInteractivity>