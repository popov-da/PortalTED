umber="ГОСТ 9805-84" data-supplyNumberType="sp01">ГОСТ 9805-84</div></td><td><div class="reqQuantity"></div></td><td></td></tr>				</tbody></table></span>				<span class="reqSpares prelimTable formalTable" id="reqSpares_IDNBPA14JP"><table><caption></caption><caption class="rest"></caption><thead><tr><th class="prelimTable__name"></th><th class="prelimTable__identification"></th><th class="prelimTable__qty"></th><th class="prelimTable__remark"></th></tr></thead><tbody>					<tr class="row__noSpares"><td class="noSpares" colspan="4"></td></tr>				</tbody></table></span>				<div class="reqSafety">					<div class="safetyRqmts">						<div><div class="warning">							<div class="warningAndCautionPara p">РАБОТЫ ВЫПОЛНЯТЬ НА ОБЕСТОЧЕННОМ ОБОРУДОВАНИИ.</div>							<div class="warningAndCautionPara p">РАБОТЫ ВЫПОЛНЯТЬ БЕЗ УСТАНОВЛЕННОГО ГРУЗА.</div>						</div></div>					</div>				</div>			</div>			<div><div class="mainProcedure" id="mainProcedure_IDNN3OGQT5"></div></div><div class="Procedure levels" id="">				<div class="proceduralStep level1 link" id="proceduralStep_IDNGGEKW5Z">					<div class="title">Подготовительные работы</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDLAONPND4">						<div class="para p">Выполните спуск траверсы <a class="dmRef  link" href="MTPA-A-07-10-00-00A-176A-A.htm"><div class="dmRefIdent">									<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="176" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="00" data-subSubSystemCode="0" data-subSystemCode="1" data-systemCode="07" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-07-10-00-00A-176A-A</div>								</div></a>.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_ID2PU512CE">						<div class="para p">Обеспечьте доступ <a class="dmRef  link" href="MTPA-A-D2-72-00-00A-540A-A.htm"><div class="dmRefIdent">									<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="540" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="00" data-subSubSystemCode="2" data-subSystemCode="7" data-systemCode="D2" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-D2-72-00-00A-540A-A</div>								</div></a>.</div>					</div>				</div>				<div class="proceduralStep level1 link" id="proceduralStep_IDHAOWMYF2">					<div class="title">Осмотр</div>					<div class="proceduralStep level2 link" id="proceduralStep_ID1HNBQR1J">						<div class="title">Осмотр шкафа управления</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDVL3ULMHP">							<div class="para p">Осмотрите шкаф управления на отсутствие загрязнений.</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDHR1Y5GMS">								<div class="para p">При наличии загрязнений удалите их обтирочной ветошью. Сильные загрязнения удалитеобтирочной ветошью, смоченной растворителем.</div>							</div>						</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDIB3UYLZN">							<div class="para p">Осмотрите  шкаф управления на отсутствие сколов, царапин, трещин, вмятин, деформаций, разрушений и других механических повреждений.</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDYQV1E4SP">								<div class="para p">При необходимости выполните замену шкафа управления <a class="dmRef  link" href="MTPA-A-D2-72-00-00A-922A-A.htm"><div class="dmRefIdent">											<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="922" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="00" data-subSubSystemCode="2" data-subSystemCode="7" data-systemCode="D2" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-D2-72-00-00A-922A-A</div>										</div></a>.</div>							</div>						</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDIWY4EZ1E">							<div class="para p">Убедитесь в надежности крепления шкафа управления.</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDQHVBFNAG">								<div class="para p">При необходимости затяните слабо затянутые крепежные элементы.</div>							</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDSKROGT0V">								<div class="para p">При необходимости установите на свои места недостающие крепежные элементы.</div>							</div>						</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDBTQBVWRF">							<div class="para p">Убедитесь в отсутствии механических повреждений на крепежных элементах шкафа управления.</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDHE3ZJEDL">								<div class="para p">При необходимости замените поврежденные крепежные элементы на новые.</div>							</div>						</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDYNWFWYQN">							<div class="para p">Осмотрите электрические соединители на отсутствие загрязнений.</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDNZHTJWEE">								<div class="para p">При наличии загрязнений удалите их обтирочной ветошью. Сильные загрязнения удалитеобтирочной ветошью, смоченной спиртом.</div>							</div>						</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDSAFTWL3V">							<div class="para p">Осмотрите электрические соединители на отсутствие сколов, трещин, вмятин, следов температурного воздействия и других механических повреждений.</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDOKLHXVJ4">								<div class="para p">При необходимости выполните замену электрических соединителей.</div>							</div>						</div>						<div class="proceduralStep level3 link" id="proceduralStep_ID5X4VJJRI">							<div class="para p">Убедитесь в надежности крепления электрических соединителей.				</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDPDF0ZO3L">								<div class="para p">При необходимости затяните слабо затянутые крепежные элементы.</div>							</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDARXEJVHZ">								<div class="para p">При необходимости установите на свои места недостающие крепежные элементы.</div>							</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDAHVG2BYM">								<div class="para p">При необходимости выполните снятие и установку электрических соединителей.</div>							</div>						</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDSCUC2W40">							<div class="para p">Убедитесь в отсутствии механических повреждений на крепежных элементах электрических соединителей.</div>							<div class="proceduralStep level4 link" id="proceduralStep_ID0DITTREW">								<div class="para p">При необходимости замените поврежденные крепежные элементы на новые.</div>							</div>						</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDCZX3ACIY">						<div class="title">Осмотр кнопки аварийной остановки</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDCHUEGRLR">							<div class="para p">Осмотрите кнопку на отсутствие загрязнений.</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDIYMVJO5R">								<div class="para p">При наличии загрязнений удалите их обтирочной ветошью. Сильные загрязнения удалитеобтирочной ветошью, смоченной спиртом.</div>							</div>						</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDWAMGCRK1">							<div class="para p">Осмотрите кнопку на отсутствие сколов, царапин, трещин, вмятин, деформаций, разрушений, следов температурного воздействия и других механических повреждений.</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDGLKHH5T5">								<div class="para p">При необходимости выполните замену кнопки <a class="dmRef  link" href="MTPA-A-D2-72-01-00A-922A-A.htm"><div class="dmRefIdent">											<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="922" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="01" data-subSubSystemCode="2" data-subSystemCode="7" data-systemCode="D2" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-D2-72-01-00A-922A-A</div>										</div></a>.</div>							</div>						</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDXXFGHMH4">							<div class="para p">Осмотрите кнопку на наличие маркировки.</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDC0CXUJTQ">								<div class="para p">При необходимости выполните замену кнопки <a class="dmRef  link" href="MTPA-A-D2-72-01-00A-922A-A.htm"><div class="dmRefIdent">											<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="922" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="01" data-subSubSystemCode="2" data-subSystemCode="7" data-systemCode="D2" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-D2-72-01-00A-922A-A</div>										</div></a>.</div>							</div>						</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDF1ESNX1N">							<div class="para p">Убедитесь в надежности крепления кнопки.</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDVMCSFQSQ">								<div class="para p">При необходимости затяните слабо затянутые крепежные элементы.</div>							</div>							<div class="proceduralStep level4 link" id="proceduralStep_ID2T1D0ORK">								<div class="para p">При необходимости установите на свои места недостающие крепежные элементы.</div>							</div>						</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDVSKISR4Q">							<div class="para p">Осмотрите провода на отсутствие загрязнений.</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDZBHFNRS4">								<div class="para p">При наличии загрязнений удалите их обтирочной ветошью. Сильные загрязнения удалитеобтирочной ветошью, смоченной спиртом.</div>							</div>						</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDW5DI1BJT">							<div class="para p">Осмотрите провода на отсутствие повреждений изоляции и экранирующих оболочек,  крутых изгибов, скручиваний, растрескиваний от термического воздействия и других механических повреждений.</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDVIHH1WX2">								<div class="para p">При необходимости выполните замену поврежденных проводов.</div>							</div>						</div>						<div class="proceduralStep level3 link" id="proceduralStep_ID5JMUBLWZ">							<div class="para p">Убедитесь в надежности крепления проводов.</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDJ5EZUEVN">								<div class="para p">При необходимости затяните слабо затянутые крепежные элементы.</div>							</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDX2RE4IFT">								<div class="para p">При необходимости установите на свои места недостающие крепежные элементы.</div>							</div>						</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDWACPFF0N">						<div class="title">Осмотр перфорированного короба  </div>						<div class="proceduralStep level3 link" id="proceduralStep_IDS1GI4UKQ">							<div class="para p">Осмотрите короб на отсутствие загрязнений.</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDANTE54U5">								<div class="para p">При наличии загрязнений удалите их обтирочной ветошью. Сильные загрязнения удалитеобтирочной ветошью, смоченной растворителем.</div>							</div>						</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDMRQSYVY0">							<div class="para p">Осмотрите короб на отсутствие сколов, царапин, трещин, вмятин, деформаций, разрушений, следов температурного воздействия и других механических повреждений.</div>							<div class="proceduralStep level4 link" id="proceduralStep_ID33HWVTSO">								<div class="para p">При необходимости выполните замену <spa