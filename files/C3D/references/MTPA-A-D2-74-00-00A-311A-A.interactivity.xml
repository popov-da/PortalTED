umber="ГОСТ 9805-84" data-supplyNumberType="sp01">ГОСТ 9805-84</div></td><td><div class="reqQuantity"></div></td><td></td></tr>				</tbody></table></span>				<span class="reqSpares prelimTable formalTable" id="reqSpares_IDWX21IYGS"><table><caption></caption><caption class="rest"></caption><thead><tr><th class="prelimTable__name"></th><th class="prelimTable__identification"></th><th class="prelimTable__qty"></th><th class="prelimTable__remark"></th></tr></thead><tbody>					<tr class="row__noSpares"><td class="noSpares" colspan="4"></td></tr>				</tbody></table></span>				<div class="reqSafety">					<div class="safetyRqmts">						<div><div class="warning">							<div class="warningAndCautionPara p">РАБОТЫ ВЫПОЛНЯТЬ НА ОБЕСТОЧЕННОМ ОБОРУДОВАНИИ.</div>							<div class="warningAndCautionPara p">РАБОТЫ ВЫПОЛНЯТЬ БЕЗ УСТАНОВЛЕННОГО ГРУЗА.</div>						</div></div>					</div>				</div>			</div>			<div><div class="mainProcedure" id="mainProcedure_IDOVOLA0Y0"></div></div><div class="Procedure levels" id="">				<div class="proceduralStep level1 link" id="proceduralStep_IDGZZM0JUY">					<div class="title">Подготовительные работы</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDRPEY0PTF">						<div class="para p">Выполните спуск траверсы <a class="dmRef  link" href="MTPA-A-07-10-00-00A-176A-A.htm"><div class="dmRefIdent">									<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="176" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="00" data-subSubSystemCode="0" data-subSystemCode="1" data-systemCode="07" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-07-10-00-00A-176A-A</div>								</div></a>.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDPYSBC35T">						<div class="para p">Обеспечьте доступ <a class="dmRef  link" href="MTPA-A-D2-72-00-00A-540A-A.htm"><div class="dmRefIdent">									<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="540" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="00" data-subSubSystemCode="2" data-subSystemCode="7" data-systemCode="D2" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-D2-72-00-00A-540A-A</div>								</div></a>.</div>					</div>				</div>				<div class="proceduralStep level1 link" id="proceduralStep_IDKTFSHD0C">					<div class="title">Осмотр</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDVOJ4FIEA">						<div class="title">Осмотр распределительной коробки</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDXV44T0VZ">							<div class="para p">Осмотрите распределительную коробку на отсутствие загрязнений.</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDIEEWANMA">								<div class="para p">При наличии загрязнений удалите их обтирочной ветошью. Сильные загрязнения удалитеобтирочной ветошью, смоченной растворителем.</div>							</div>						</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDJWVKNF1U">							<div class="para p">Осмотрите  распределительную коробку на отсутствие сколов, царапин, трещин, вмятин, деформаций, разрушений и других механических повреждений.</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDZLLAGG5R">								<div class="para p">При необходимости выполните замену распределительной коробки <a class="dmRef  link" href="MTPA-A-D2-74-00-00A-922A-A.htm"><div class="dmRefIdent">											<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="922" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="00" data-subSubSystemCode="4" data-subSystemCode="7" data-systemCode="D2" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-D2-74-00-00A-922A-A</div>										</div></a>.</div>							</div>						</div>						<div class="proceduralStep level3 link" id="proceduralStep_ID0ND4SMLS">							<div class="para p">Убедитесь в надежности крепления распределительной коробки.</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDQVV5WL0E">								<div class="para p">При необходимости затяните слабо затянутые крепежные элементы.</div>							</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDDFDUUFLI">								<div class="para p">При необходимости установите на свои места недостающие крепежные элементы.</div>							</div>						</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDNI0JNWP3">							<div class="para p">Убедитесь в отсутствии механических повреждений на крепежных элементах распределительной коробки.</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDD2E1QRD4">								<div class="para p">При необходимости замените поврежденные крепежные элементы на новые.</div>							</div>						</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDHWJ2MEPI">							<div class="para p">Осмотрите электрические соединители на отсутствие загрязнений.</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDFHQWONL4">								<div class="para p">При наличии загрязнений удалите их обтирочной ветошью. Сильные загрязнения удалитеобтирочной ветошью, смоченной спиртом.</div>							</div>						</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDU1NPEF1R">							<div class="para p">Осмотрите электрические соединители на отсутствие сколов, трещин, вмятин, следов температурного воздействия и других механических повреждений.</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDKUPEOXL2">								<div class="para p">При необходимости выполните замену электрических соединителей.</div>							</div>						</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDAUSICBUG">							<div class="para p">Убедитесь в надежности крепления электрических соединителей.				</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDIXHXUALQ">								<div class="para p">При необходимости затяните слабо затянутые крепежные элементы.</div>							</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDSF3QY3ZY">								<div class="para p">При необходимости установите на свои места недостающие крепежные элементы.</div>							</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDCHWABWT5">								<div class="para p">При необходимости выполните снятие и установку электрических соединителей. </div>							</div>						</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDGGVJRV2V">							<div class="para p">Убедитесь в отсутствии механических повреждений на крепежных элементах электрических соединителей.</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDE3EMAOGH">								<div class="para p">При необходимости замените поврежденные крепежные элементы на новые.</div>							</div>						</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_ID2ERBDU2Q">						<div class="title">Осмотр оборудования в распределительной коробки</div>						<div class="proceduralStep level3 link" id="proceduralStep_ID0T1I1CFK">							<div class="para p">Осмотрите провода на отсутствие загрязнений.</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDLKLYDQIL">								<div class="para p">При наличии загрязнений удалите их обтирочной ветошью. Сильные загрязнения удалитеобтирочной ветошью, смоченной спиртом.</div>							</div>						</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDGKHXZWQL">							<div class="para p">Осмотрите провода на отсутствие повреждений изоляции и экранирующих оболочек,  крутых изгибов, скручиваний, растрескиваний от термического воздействия и других механических повреждений.</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDAO3TWYVW">								<div class="para p">При необходимости выполните замену поврежденных проводов.</div>							</div>						</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDDFH1TES4">							<div class="para p">Убедитесь в надежности крепления проводов.</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDCVRSMIP5">								<div class="para p">При необходимости затяните слабо затянутые крепежные элементы.</div>							</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDH423TAVU">								<div class="para p">При необходимости установите на свои места недостающие крепежные элементы.</div>							</div>							<div class="proceduralStep level4 link" id="proceduralStep_IDXFBP5QNL">								<div class="para p">При необходимости выполните снятие и установку проводов.</div>							</div>						</div>					</div>				</div>				<div class="proceduralStep level1 link" id="proceduralStep_IDGEEVA45U">					<div class="title">Заключительные работы</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDZOAR10EM">						<div class="para p">Очистите зону выполнения работ и убедитесь в отсутствии посторонних предметов.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDD1AVZ2SS">						<div class="para p">Закройте дверцу шкафа <a class="dmRef  link" href="MTPA-A-D2-72-00-00A-740A-A.htm"><div class="dmRefIdent">									<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="740" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="00" data-subSubSystemCode="2" data-subSystemCode="7" data-systemCode="D2" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-D2-72-00-00A-740A-A</div>								</div></a>.</div>					</div>				</div>			</div>			<div class="closeRqmts" id="closeRqmts_IDFFMH4MSE">				<span class="reqCondGroup formalTable" id="reqCondGroup_IDNQUZCH2F"><table><caption></caption><caption class="rest"></caption><thead><tr><th colspan="3"><span class="condition"></span></th><th colspan="3"><span class="publication"></span></th></tr></thead><tbody>					<tr class="row__noConds"><td class="noConds" colspan="6"></td></tr>				</tbody></table></span>			</div>		</div>	</div></div>]]></DocumentTemplate></SimulationInteractivity>