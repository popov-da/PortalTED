identAndStatusSection link" data-link="toggleStatus">		<div class="dmAddress">			<div class="dmIdent">				<div class="dmCode" data-modelIdentCode="MTPA" data-systemDiffCode="A" data-systemCode="D2" data-subSystemCode="9" data-subSubSystemCode="3" data-assyCode="00" data-disassyCode="00" data-disassyCodeVariant="A" data-infoCode="041" data-infoCodeVariant="A" data-itemLocationCode="A">MTPA-A-D2-93-00-00A-041A-A</div>				<div class="language" data-countryIsoCode="RU" data-languageIsoCode="ru"></div>				<div class="issueInfo" data-issueNumber="001" data-inWork="01"></div>			</div>			<div class="dmAddressItems">				<div class="issueDate" data-year="2025" data-month="05" data-day="30"></div>				<div class="dmTitle">					<div class="techName">						Планшет					</div>					<div class="infoName">Описание и работа</div>				</div>			</div>		</div>		<div class="dmStatus" data-issueType="new">			<div class="security" data-securityClassification="01"></div>			<div class="responsiblePartnerCompany" data-enterpriseCode="MDMKD">				<div class="enterpriseName">МОДУЛЬ МВД</div>			</div>			<div class="originator" data-enterpriseCode="MDMKD">				<div class="enterpriseName">МОДУЛЬ МКД</div>			</div>			<div class="applic">				<div class="displayText">					<div class="simplePara">ВСЕ</div>				</div>			</div>			<div class="brexDmRef">				<a class="dmRef  link" data-type="simple" data-actuate="onRequest" data-show="replace" data-href="URN:S1000D:DMC-S1000D-E-04-10-0301-00A-022A-D" href="S1000D-E-04-10-0301-00A-022A-D.htm"><div class="dmRefIdent">						<div class="dmCode" data-modelIdentCode="S1000D" data-systemDiffCode="E" data-systemCode="04" data-subSystemCode="1" data-subSubSystemCode="0" data-assyCode="0301" data-disassyCode="00" data-disassyCodeVariant="A" data-infoCode="022" data-infoCodeVariant="A" data-itemLocationCode="D">S1000D-E-04-10-0301-00A-022A-D</div>					</div></a>			</div>			<div class="qualityAssurance">				<div class="unverified"></div>			</div>		</div>	</div>	<div class="content">		<div class="description levels" id="description_IDAWHVKWZF">			<div class="levelledPara level1 link" id="levelledPara_IDTVJWSKTS">				<div class="title">Общие сведения</div>				<div class="levelledPara level2 link" id="levelledPara_ID2URMHXBA">					<div class="title">Назначение</div>					<div class="para p"></div>					<div class="para p">						Планшет Getac F110 предназначен для отображения информации о текущем состоянии системы и осуществления управления траверсой.</div>				</div>				<div class="levelledPara level2 link" id="levelledPara_IDRX4CLXEF">					<div class="title">Технические характеристики</div>					<div class="para p">Технические характеристики планшета <a class="internalRef irtt02 link" data-index="1" href="#tab-002" title=""></a>					</div>					<div class="table" id="tab-002"><div class="table-contents">						<div class="title">Технические характеристики планшета</div>						<table summary="Технические характеристики планшета" style="border-collapse: collapse;border-top: 1px solid ; border-bottom: 1px solid ; border-left: 1px solid ; border-right: 1px solid ; "><caption><div class="title">Технические характеристики планшета</div></caption><caption class="rest"><div class="title">Технические характеристики планшета</div></caption><colgroup><col width="50%" align="center" class="col1"><col width="50%" align="center" class="col2"></colgroup><thead><tr><th style="border-right: 1px solid ; border-bottom: 1px solid ; " align="center">										<div class="para p">Наименование параметра</div>									</th><th style="border-bottom: 1px solid ; " align="center">										<div class="para p">Значение</div>									</th></tr></thead><tbody><tr><td style="border-right: 1px solid ; border-bottom: 1px solid ; " align="left">										<div class="para p">Габаритные размеры (Д×Г×В), мм, не более</div>									</td><td style="border-bottom: 1px solid ; " align="center">										<div class="para p">314×207×25</div>									</td></tr><tr><td style="border-right: 1px solid ; border-bottom: 1px solid ; " align="left">										<div class="para p">Масса, кг, не более</div>									</td><td style="border-bottom: 1px solid ; " align="center">										<div class="para p">1.49</div>									</td></tr><tr><td style="border-right: 1px solid ; border-bottom: 1px solid ; " align="left">										<div class="para p">Операционная система</div>									</td><td style="border-bottom: 1px solid ; " align="center">										<div class="para p">Windows 11 Pro</div>									</td></tr><tr><td style="border-right: 1px solid ; border-bottom: 1px solid ; " align="left">										<div class="para p">Дисплей</div>									</td><td style="border-bottom: 1px solid ; " align="center">										<div class="para p">11.6" TFT LCD FHD (1920 x 1080) с широким углом обзора</div>									</td></tr><tr><td style="border-right: 1px solid ; border-bottom: 1px solid ; " align="left">										<div class="para p">Рабочая температура, С°</div>									</td><td style="border-bottom: 1px solid ; " align="center">										<div class="para p">от -29 до +50 </div>									</td></tr><tr><td style="border-right: 1px solid ; border-bottom: 1px solid ; " align="left">										<div class="para p">Температура хранения, С°</div>									</td><td style="border-bottom: 1px solid ; " align="center">										<div class="para p">от -51 до +71 </div>									</td></tr><tr><td style="border-right: 1px solid ; border-bottom: 1px solid ; " align="left">										<div class="para p">Напряжение аккумулятора, В </div>									</td><td style="border-bottom: 1px solid ; " align="center">										<div class="para p">11.4 </div>									</td></tr><tr><td style="border-right: 1px solid ; border-bottom: 1px solid ; " align="left">										<div class="para p">Ёмкость аккумулятора, мА·ч</div>									</td><td style="border-bottom: 1px solid ; " align="center">										<div class="para p">2680</div>									</td></tr><tr><td style="border-right: 1px solid ; " align="left">										<div class="para p">Аксессуары</div>									</td><td style="" align="center">										<div class="para p">Стилус для емкостного экрана с проводом</div>									</td></tr></tbody></table>					</div></div><br class="table-break">				</div>			</div>			<div class="levelledPara level1 link" id="levelledPara_ID1QL42IDY">				<div class="title">Описание</div>				<div class="para p">										Оператор осуществляет управление траверсой с помощью планшета.</div>				<div class="para p">На лицевой стороне планшета расположен мультитач-экран, кнопка включения и выключения, четыре программируемые физические кнопки, а также веб-камера для обеспечения доступа к программам планшета через распознавание лица.</div>				<div class="para p">На боковых сторонах корпуса размещены точки подключения планшета, имеющие следующие обозначения и функции:<div class="randomList list  ul">						<div class="listItem li"><div class="listItemBody">							<div class="para p">разъем «Docking Connector» предназначен для подключения планшета к док-станции, обеспечивая зарядку и расширение портов;</div>						</div></div>						<div class="listItem li"><div class="listItemBody">							<div class="para p">разъем «USB 3.2 Gen 2 Type-A» предназначен подключения различных USB-устройств, таких как флеш-накопители, клавиатуры, мыши и другие периферийные устройства;							</div>						</div></div>						<div class="listItem li"><div class="listItemBody">							<div class="para p">разъем «Thunderbolt™ 4 Type-C» обеспечивает высокоскоростную передачу данных и поддержку подключения внешних дисплеев и других устройств;</div>						</div></div>						<div class="listItem li"><div class="listItemBody">							<div class="para p">разъем «HDMI» предназначен для подключения внешних мониторов или проекторов, поддерживающих HDMI-вход;</div>						</div></div>						<div class="listItem li"><div class="listItemBody">							<div class="para p">разъем «VGA (D-sub 15 pin)» предназначен для подключения старых мониторов или проекторов, использующих VGA-разъём;</div>						</div></div>						<div class="listItem li"><div class="listItemBody">							<div class="para p">разъем «RJ45 (Ethernet)» предназначен для подключения к проводной сети Ethernet, обеспечивая стабильное и быстрое интернет-соединение;</div>						</div></div>						<div class="listItem li"><div class="listItemBody">							<div class="para p">разъем «Аудиоразъём (Combo Audio Jack)» предназначен для подключения наушников или микрофона;</div>						</div></div>						<div class="listItem li"><div class="listItemBody">							<div class="para p">разъем «DC-in Jack (разъём питания)» предназначен для подключения зарядного устройства или адаптера питания;</div>						</div></div>						<div class="listItem li"><div class="listItemBody">							<div class="para p">разъем «SIM Card Slot (слот для SIM-карты)» предназначен для установки SIM-карты, обеспечивая возможность подключения к мобильным сетям;</div>						</div></div>						<div class="listItem li"><div class="listItemBody">							<div class="para p">разъем «RF Antenna Pass-through» предназначен для подключения внешних антенн, улучшая качество сигнала для GPS, WWAN и WLAN.</div>						</div></div>					</div>				</div>				<div class="para p">На задней стороне корпуса установлены два съёмных литий-ионных аккумулятора. В специальном отсеке размещён стилус, соединённый с корпусом планшета пружинным проводом. Так же в верхней части расположена тыловая камера.</div>			</div>			<div class="levelledPara level1 link" id="levelledPara_IDKRULH3QZ">				<div class="title">Работа</div>				<div class="para p">Для сетевой интеграции планшета и траверсы необходимо включить планшет, активировать интерфейс в разделе «Сетевые настройки», включить Wi-Fi модуль и установить связь с траверсой. После установления соединения планшету отобразится статус «Соединено», свидетельствующий о готовности к управлению.</div>			</div>		</div>	</div></div>]]></DocumentTemplate></SimulationInteractivity>