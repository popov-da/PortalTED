дра управления малого телескопа" flags="33">ICN-MTPA-A-K11006-0-MDMKD-00001-A-001-01.svg</Picture></Resources><DocumentTemplate><![CDATA[<div class="dmodule">	<div class="identAndStatusSection link" data-link="toggleStatus">		<div class="dmAddress">			<div class="dmIdent">				<div class="dmCode" data-modelIdentCode="MTPA" data-systemDiffCode="A" data-systemCode="K1" data-subSystemCode="3" data-subSubSystemCode="0" data-assyCode="04" data-disassyCode="00" data-disassyCodeVariant="A" data-infoCode="922" data-infoCodeVariant="A" data-itemLocationCode="A">MTPA-A-K1-30-04-00A-922A-A</div>				<div class="language" data-countryIsoCode="RU" data-languageIsoCode="ru"></div>				<div class="issueInfo" data-issueNumber="001" data-inWork="01"></div>			</div>			<div class="dmAddressItems">				<div class="issueDate" data-year="2025" data-month="05" data-day="30"></div>				<div class="dmTitle">					<div class="techName">Гидроцилиндр управления малого телескопа</div>					<div class="infoName">Демонтаж и монтаж</div>				</div>			</div>		</div>		<div class="dmStatus" data-issueType="new">			<div class="security" data-securityClassification="01"></div>			<div class="responsiblePartnerCompany" data-enterpriseCode="MDMKD">				<div class="enterpriseName">МОДУЛЬ МКД</div>			</div>			<div class="originator" data-enterpriseCode="MDMKD">				<div class="enterpriseName">МОДУЛЬ МКД</div>			</div>			<div class="applic">				<div class="displayText">					<div class="simplePara">ВСЕ</div>				</div>			</div>			<div class="brexDmRef">				<a class="dmRef  link" data-type="simple" data-actuate="onRequest" data-show="replace" data-href="URN:S1000D:DMC-S1000D-E-04-10-0301-00A-022A-D" href="S1000D-E-04-10-0301-00A-022A-D.htm"><div class="dmRefIdent">						<div class="dmCode" data-modelIdentCode="S1000D" data-systemDiffCode="E" data-systemCode="04" data-subSystemCode="1" data-subSubSystemCode="0" data-assyCode="0301" data-disassyCode="00" data-disassyCodeVariant="A" data-infoCode="022" data-infoCodeVariant="A" data-itemLocationCode="D">S1000D-E-04-10-0301-00A-022A-D</div>					</div></a>			</div>			<div class="qualityAssurance">				<div class="unverified"></div>			</div>		</div>	</div>	<div class="content">		<div class="procedure">			<div class="preliminaryRqmts" id="preliminaryRqmts_ID0PONDNPH">				<span class="reqCondGroup formalTable" id="reqCondGroup_IDT5JRTCSA"><table><caption></caption><caption class="rest"></caption><thead><tr><th colspan="3"><span class="condition"></span></th><th colspan="3"><span class="publication"></span></th></tr></thead><tbody>					<tr class="row__noConds"><td class="noConds" colspan="6"></td></tr>				</tbody></table></span>				<span class="reqSupportEquips prelimTable formalTable" id="reqSupportEquips_IDFUOIBBD3"><table><caption></caption><caption class="rest"></caption><thead><tr><th class="prelimTable__name"></th><th class="prelimTable__identification"></th><th class="prelimTable__qty"></th><th class="prelimTable__remark"></th></tr></thead><tbody>					<tr class="row__noSupportEquips"><td class="noSupportEquips" colspan="4"></td></tr>				</tbody></table></span>				<span class="reqSupplies prelimTable formalTable" id="reqSupplies_IDIHA251IZ"><table><caption></caption><caption class="rest"></caption><thead><tr><th class="prelimTable__name"></th><th class="prelimTable__identification"></th><th class="prelimTable__qty"></th><th class="prelimTable__remark"></th></tr></thead><tbody>					<tr class="supplyDescr"><td><div><div class="name">Ветошь обтирочная</div></div></td><td class="prelimTable_identification"><div class="supplyRef" data-supplyNumber="ГОСТ 4643-75" data-supplyNumberType="sp01">ГОСТ 4643-75</div></td><td><div class="reqQuantity"></div></td><td></td></tr><tr class="supplyDescr"><td><div><div class="name">Сорбирующие салфетки</div></div></td><td class="prelimTable_identification"><div class="supplyRef" data-supplyNumber="Econadin" data-supplyNumberType="sp01">Econadin</div></td><td><div class="reqQuantity"></div></td><td></td></tr><tr class="supplyDescr"><td><div><div class="name">Спирт изопропиловый</div></div></td><td class="prelimTable_identification"><div class="supplyRef" data-supplyNumber="ГОСТ 9805-84" data-supplyNumberType="sp01">ГОСТ 9805-84</div></td><td><div class="reqQuantity"></div></td><td></td></tr>				</tbody></table></span>				<span class="reqSpares prelimTable formalTable" id="reqSpares_IDZHSBJC2B"><table><caption></caption><caption class="rest"></caption><thead><tr><th class="prelimTable__name"></th><th class="prelimTable__identification"></th><th class="prelimTable__qty"></th><th class="prelimTable__remark"></th></tr></thead><tbody>					<tr class="row__noSpares"><td class="noSpares" colspan="4"></td></tr>				</tbody></table></span>				<div class="reqSafety">					<div class="safetyRqmts">						<div><div class="warning" id="wrn-001">							<div class="warningAndCautionPara p">РАБОТЫ ВЫПОЛНЯТЬ БЕЗ УСТАНОВЛЕННОГО ГРУЗА.</div>							<div class="warningAndCautionPara p">РАБОТЫ ВЫПОЛНЯТЬ НА ОБЕСТОЧЕННОМ ОБОРУДОВАНИИ.</div>						</div></div>					</div>				</div>			</div>			<div><div class="mainProcedure" id="mainProcedure_ID2BEXZ5OG"></div></div><div class="Procedure levels" id="">				<div class="proceduralStep level1 link" id="proceduralStep_IDG15GQOKG">					<div class="title">Подготовительные работы</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDDKJMU3Z5">						<div class="para p">Выполните отключение траверсы  <a class="dmRef  link" href="MTPA-A-20-11-00-00A-510A-A.htm"><div class="dmRefIdent">									<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="510" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="00" data-subSubSystemCode="1" data-subSystemCode="1" data-systemCode="20" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-20-11-00-00A-510A-A</div>								</div></a>.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDL1IWH02O">						<div class="para p">Вывесите траверсу, обеспечив доступ к нижней части.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDRIOHKUCY">						<div class="para p">Установите ложементы для страховки персонала.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDGSST0V3D">						<div class="para p">Зафиксируйте траверсу в воздухе со всех сторон.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDNSHZ42PA">						<div class="para p">Подготовьте тару для слива масла.</div>					</div>				</div>				<div class="proceduralStep level1 link" id="proceduralStep_ID2HTNNUHE">					<div class="title">Демонтаж</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDHQWFQZW1">						<div class="para p">Отверните 						накидные гайки <a class="internalRef irtt11 link" data-figure="1" data-referredFragment="4" data-linkByName="true" data-link="link2d" data-src="ICN-MTPA-A-K11006-0-MDMKD-00001-A-001-01.cgm" data-title="Демонтаж и монтаж гидроцилиндра управления малого телескопа" title="4"></a> трубопроводов от штуцеров <a class="internalRef irtt11 link" data-figure="1" data-referredFragment="3" data-linkByName="true" data-link="link2d" data-src="ICN-MTPA-A-K11006-0-MDMKD-00001-A-001-01.cgm" data-title="Демонтаж и монтаж гидроцилиндра управления малого телескопа" title="3"></a> гидроцилиндра <a class="internalRef irtt11 link" data-figure="1" data-referredFragment="5" data-linkByName="true" data-link="link2d" data-src="ICN-MTPA-A-K11006-0-MDMKD-00001-A-001-01.cgm" data-title="Демонтаж и монтаж гидроцилиндра управления малого телескопа" title="5"></a>.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_ID0HZ2YL4K">						<div class="para p">Слейте масло из трубопроводов и гидроцилиндра <a class="internalRef irtt11 link" data-figure="1" data-referredFragment="5" data-linkByName="true" data-link="link2d" data-src="ICN-MTPA-A-K11006-0-MDMKD-00001-A-001-01.cgm" data-title="Демонтаж и монтаж гидроцилиндра управления малого телескопа" title="5"></a> в тару для слива масла.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDEOF13ZZV">						<div class="para p">Установите технологические заглушки на накидные гайки <a class="internalRef irtt11 link" data-figure="1" data-referredFragment="7" data-linkByName="true" data-link="link2d" data-src="ICN-MTPA-A-K11006-0-MDMKD-00001-A-001-01.cgm" data-title="Демонтаж и монтаж гидроцилиндра управления малого телескопа" title="7"></a> трубопроводов.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDJYCXDTYS">						<div class="para p">Удалите контровку шплинтов <a class="internalRef irtt11 link" data-figure="1" data-referredFragment="7" data-linkByName="true" data-link="link2d" data-src="ICN-MTPA-A-K11006-0-MDMKD-00001-A-001-01.cgm" data-title="Демонтаж и монтаж гидроцилиндра управления малого телескопа" title="7"></a>.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDUAPVXABV">						<div class="para p">Снимите шплинты <a class="internalRef irtt11 link" data-figure="1" data-referredFragment="7" data-linkByName="true" data-link="link2d" data-src="ICN-MTPA-A-K11006-0-MDMKD-00001-A-001-01.cgm" data-title="Демонтаж и монтаж гидроцилиндра управления малого телескопа" title="7"></a> из оси <a class="internalRef irtt11 link" data-figure="1" data-referredFragment="1" data-linkByName="true" data-link="link2d" data-src="ICN-MTPA-A-K11006-0-MDMKD-00001-A-001-01.cgm" data-title="Демонтаж и монтаж гидроцилиндра управления малого телескопа" title="1"></a> гидроцилиндра <a class="internalRef irtt11 link" data-figure="1" data-referredFragment="5" data-linkByName="true" data-link="link2d" data-src="ICN-MTPA-A-K11006-0-MDMKD-00001-A-001-01.cgm" data-title="Демонтаж и монтаж гидроцилиндра управления малого телескопа" title="5"></a>.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_ID540ZPKPQ">						<div class="para p">Снимите 		оси <a class="internalRef irtt11 link" data-figure="1" data-referredFragment="1" data-linkByName="true" data-link="link2d" data-src="ICN-MTPA-A-K11006-0-MDMKD-00001-A-001-01.cgm" data-title="Демонтаж и монтаж гидроцилиндра управления малого телескопа" title="1"></a>, шайбы <a class="internalRef irtt11 link" data-figure="1" data-referredFragment="8" data-linkByName="true" data-link="link2d" data-src="ICN-MTPA-A-K11006-0-MDMKD-00001-A-001-01.cgm" data-title="Демонтаж и монтаж гидроцилиндра управления малого телескопа" title="8"></a> и гидроцилиндр <a class="internalRef irtt11 link" data-figure="1" data-referredFragment="5" data-linkByName="true" data-link="link2d" data-src="ICN-MTPA-A-K11006-0-MDMKD-00001-A-001-01.cgm" data-title="Демонтаж и монтаж гидроцилиндра управления малого телескопа" title="5"></a> с кронштейнов <a class="internalRef irtt11 link" data-figure="1" data-referredFragment="9" data-linkByName="true" data-link="link2d" data-src="ICN-MTPA-A-K11006-0-MDMKD-00001-A-001-01.cgm" data-title="Демонтаж и монтаж гидроцилиндра управления малого телескопа" title="9"></a>, <a class="internalRef irtt11 link" data-figure="1" data-referredFragment="6" data-linkByName="true" data-link="link2d" data-src="ICN-MTPA-A-K11006-0-MDMKD-00001-A-001-01.cgm" data-title="Демонтаж и монтаж гидроцилиндра управления малого телескопа" title="6"></a>.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDUH1LMQSO">						<div class="para p">Слейте остатки масла из гидроцилиндра <a class="internalRef irtt11 link" data-figure="1" data-referredFragment="5" data-linkByName="true" data-link="link2d" data-src="ICN-MTPA-A-K11006-0-MDMKD-00001-A-001-01.cgm" data-title="Демонтаж и монтаж гидроцилиндра управления малого телескопа" title="5"></a>		 в тару для слива масла.</div>					</div>				</div>				<div class="proceduralStep level1 link" id="proceduralStep_ID1JHZP1DL">					<div class="title">Осмотр перед монтажом</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDOTZAT3Y3">						<div class="para p">						Осмотрите гидроцилиндр <a class="internalRef irtt11 link" data-figure="1" data-referredFragment="5" data-linkByName="true" data-link="link2d" data-src="ICN-MTPA-A-K11006-0-MDMKD-00001-A-001-01.cgm" data-title="Демонтаж и монтаж гидроцилиндра управления малого телескопа" title="5"></a> на отсутствие загрязнений, сколов, трещин и другихмеханических повреждений.</div>						<div class="proceduralStep level3 link" id="proceduralStep_ID4GWPTCNW">							<div class="para p">			При наличии загрязнений удалите их обтирочной ветошью. Сильные загрязнения удалитеобтирочной ветошью, смоченной растворителем.		</div>						</div>						<div class="proceduralStep level3 link" id="proceduralStep_IDRPD3YHVT">							<div class="para p">			При наличии повреждений замените гидроцилиндр на новый.		</div>						</div>					</div>				</div>				<div class="proceduralStep level1 link" id="proceduralStep_IDRRFUKVC0">					<div class="title">Монтаж</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDO5JMMYND">						<div class="para p">							Установите проушины гидроцилиндра <a class="internalRef irtt11 link" data-figure="1" data-referredFragment="5" data-linkByName="true" data-link="link2d" data-src="ICN-MTPA-A-K11006-0-MDMKD-00001-A-001-01.cgm" data-title="Демонтаж и монтаж гидроцилиндра управления малого телескопа" title="5"></a> в кронштейны <a class="internalRef irtt11 link" data-figure="1" data-referredFragment="6" data-linkByName="true" data-link="link2d" data-src="ICN-MTPA-A-K11006-0-MDMKD-00001-A-001-01.cgm" data-title="Демонтаж и монтаж гидроцилиндра управления малого телескопа" title="6"></a>, <a class="internalRef irtt11 link" data-figure="1" data-referredFragment="9" data-linkByName="true" data-link="link2d" data-src="ICN-MTPA-A-K11006-0-MDMKD-00001-A-001-01.cgm" data-title="Демонтаж и монтаж гидроцилиндра управления малого телескопа" title="9"></a>.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDSVKIKB3B">						<div class="para p">			Установите оси <a class="internalRef irtt11 link" data-figure="1" data-referredFragment="1" data-linkByName="true" data-link="link2d" data-src="ICN-MTPA-A-K11006-0-MDMKD-00001-A-001-01.cgm" data-title="Демонтаж и монтаж гидроцилиндра управления малого телескопа" title="1"></a>,		шайбы <a class="internalRef irtt11 link" data-figure="1" data-referredFragment="8" data-linkByName="true" data-link="link2d" data-src="ICN-MTPA-A-K11006-0-MDMKD-00001-A-001-01.cgm" data-title="Демонтаж и монтаж гидроцилиндра управления малого телескопа" title="8"></a> в кронштейны <a class="internalRef irtt11 link" data-figure="1" data-referredFragment="6" data-linkByName="true" data-link="link2d" data-src="ICN-MTPA-A-K11006-0-MDMKD-00001-A-001-01.cgm" data-title="Демонтаж и монтаж гидроцилиндра управления малого телескопа" title="6"></a>, <a class="internalRef irtt11 link" data-figure="1" data-referredFragment="9" data-linkByName="true" data-link="link2d" data-src="ICN-MTPA-A-K11006-0-MDMKD-00001-A-001-01.cgm" data-title="Демонтаж и монтаж гидроцилиндра управления малого телескопа" title="9"></a> и проушины гидроцилиндра <a class="internalRef irtt11 link" data-figure="1" data-referredFragment="5" data-linkByName="true" data-link="link2d" data-src="ICN-MTPA-A-K11006-0-MDMKD-00001-A-001-01.cgm" data-title="Демонтаж и монтаж гидроцилиндра управления малого телескопа" title="5"></a>.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDD2ZVSFSK">						<div class="para p">			Установите шплинты <a class="internalRef irtt11 link" data-figure="1" data-referredFragment="7" data-linkByName="true" data-link="link2d" data-src="ICN-MTPA-A-K11006-0-MDMKD-00001-A-001-01.cgm" data-title="Демонтаж и монтаж гидроцилиндра управления малого телескопа" title="7"></a> и выполните стопорение.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDC03C4FMJ">						<div class="para p">Снимите технологические заглушки с накидных гаек <a class="internalRef irtt11 link" data-figure="1" data-referredFragment="4" data-linkByName="true" data-link="link2d" data-src="ICN-MTPA-A-K11006-0-MDMKD-00001-A-001-01.cgm" data-title="Демонтаж и монтаж гидроцилиндра управления малого телескопа" title="4"></a> трубопроводов.		</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDOKZPL0GW">						<div class="para p">Установите и заверните накидные гайки 		<a class="internalRef irtt11 link" data-figure="1" data-referredFragment="7" data-linkByName="true" data-link="link2d" data-src="ICN-MTPA-A-K11006-0-MDMKD-00001-A-001-01.cgm" data-title="Демонтаж и монтаж гидроцилиндра управления малого телескопа" title="7"></a> на штуцеры <a class="internalRef irtt11 link" data-figure="1" data-referredFragment="6" data-linkByName="true" data-link="link2d" data-src="ICN-MTPA-A-K11006-0-MDMKD-00001-A-001-01.cgm" data-title="Демонтаж и монтаж гидроцилиндра управления малого телескопа" title="6"></a> до упора.</div>					</div>				</div>				<div class="proceduralStep level1 link" id="proceduralStep_IDCKCPANUJ">					<div class="title">Заключительные работы</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDQGTMZLHV">						<div class="para p">Очистите зону выполнения работ и убедитесь в отсутствии посторонних предметов.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDCQLITEKD">						<div class="para p">Выполните дозаправку гидравлической системы  <a class="dmRef  link" href="MTPA-A-12-11-00-00A-210A-A.htm"><div class="dmRefIdent">									<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="210" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="00" data-subSubSystemCode="1" data-subSystemCode="1" data-systemCode="12" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-12-11-00-00A-210A-A</div>								</div></a>.</div>					</div>					<div class="proceduralStep level2 link" id="proceduralStep_IDH5RXOA1Z">						<div class="para p">Произведите  		 функциональные испытания гидравлической системы <a class="dmRef  link" href="MTPA-A-K1-10-00-00A-340A-A.htm"><div class="dmRefIdent">									<div class="dmCode" data-itemLocationCode="A" data-infoCodeVariant="A" data-infoCode="340" data-disassyCodeVariant="A" data-disassyCode="00" data-assyCode="00" data-subSubSystemCode="0" data-subSystemCode="1" data-systemCode="K1" data-systemDiffCode="A" data-modelIdentCode="MTPA">MTPA-A-K1-10-00-00A-340A-A</div>								</div></a>.</div>					</div>				</div>				<div class="figure" id="fig-001">					<div class="title">Демонтаж и монтаж гидроцилиндра управления малого телескопа</div>					<a title="Демонтаж и монтаж гидроцилиндра управления малого телескопа" class="graphic link" data-figure="1" data-infoEntityIdent="ICN-MTPA-A-K11006-0-MDMKD-00001-A-001-01" data-href="ICN-MTPA-A-K11006-0-MDMKD-00001-A-001-01.cgm" data-reproductionHeight="210mm" data-reproductionWidth="170mm" id="fig-001-gra-001" data-link="link2d" data-src="ICN-MTPA-A-K11006-0-MDMKD-00001-A-001-01.cgm">Демонтаж и монтаж гидроцилиндра управления малого телескопа</a>				</div>			</div>			<div class="closeRqmts" id="closeRqmts_IDX4AKY2TN">				<span class="reqCondGroup formalTable" id="reqCondGroup_IDDFFZEEU1"><table><caption></caption><caption class="rest"></caption><thead><tr><th colspan="3"><span class="condition"></span></th><th colspan="3"><span class="publication"></span></th></tr></thead><tbody>					<tr class="row__noConds"><td class="noConds" colspan="6"></td></tr>				</tbody></table></span>			</div>		</div>	</div></div>]]></DocumentTemplate></SimulationInteractivity>